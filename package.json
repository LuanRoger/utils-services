{
  "name": "utils-services",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --filter './apps/*' --parallel dev",
    "start": "bun run --filter './apps/*' --parallel start",
    "build": "bun run --filter './apps/*' build",
    "env:load": "bun run --filter './apps/*' env:load",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "catalog:",
    "ultracite": "7.6.0"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "catalog": {
      "typescript": "^6",
      "@types/bun": "latest",
      "varlock": "^0.9.0"
    },
    "catalogs": {
      "web-api": {
        "@elysia/bearer": "^1.4.4",
        "@elysia/cors": "^1.4.2",
        "@elysia/server-timing": "^1.4.1",
        "elysia-rate-limit": "^4.6.2",
        "logixlysia": "^6.3.2"
      }
    }
  }
}
